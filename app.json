{
  "expo": {
    "name": "Clap Phone Finder",
    "slug": "clap-phone-finder",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "clapphonefinder",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "backgroundColor": "#000000",

    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },

    "android": {
      "package": "com.oddev.clapphonefinder",
      "versionCode": 2,

      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-foreground.png",
        "backgroundColor": "#000000"
      },

      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.VIBRATE",
        "android.permission.CAMERA",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MICROPHONE",
        "android.permission.WAKE_LOCK"
      ]
    },

    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.oddev.clapphonefinder",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Detect claps and whistles to help you find your phone.",
        "NSCameraUsageDescription": "Turn on flashlight to help locate your phone."
      }
    },

    "web": {
      "favicon": "./assets/images/favicon.png"
    },

    "plugins": [
      "expo-router",
      [
        "expo-av",
        {
          "microphonePermission": "Detect claps and whistles to help you find your phone."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Turn on flashlight to help locate your phone."
        }
      ]
    ],

    "experiments": {
      "typedRoutes": true
    },

    "extra": {
      "router": {},
      "eas": {
        "projectId": "10ac61e0-62e7-4be4-aece-783b1b504a64"
      }
    },

    "owner": "sunnyapp"
  }
}
